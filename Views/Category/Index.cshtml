@model IEnumerable<CityMarketPOS.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6"><h1>Category Management</h1></div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline shadow">
            <div class="card-header d-flex align-items-center">
                <h3 class="card-title"><i class="fas fa-list mr-2"></i> Product Categories</h3>
                <button type="button" class="btn btn-primary btn-sm ml-auto" data-toggle="modal" data-target="#createCategoryModal">
                    <i class="fas fa-plus"></i> Add Category
                </button>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Short Name</th>
                            <th>Description</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td><span class="badge badge-secondary">@item.ShortName</span></td>
                                <td>@item.Description</td>
                                <td>
                                    <div class="d-flex">
                                        <button type="button"
                                                class="btn btn-info btn-sm mr-2 edit-category-btn"
                                                data-toggle="modal"
                                                data-target="#editCategoryModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                data-shortname="@item.ShortName"
                                                data-description="@item.Description">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this category?');">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="createCategoryModal" tabindex="-1" role="dialog" aria-labelledby="createCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createCategoryModalLabel"><i class="fas fa-plus mr-2"></i> Add Category</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="Create" method="post" id="createCategoryForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="createCategoryName">Category Name <span class="text-danger">*</span></label>
                        <input type="text" id="createCategoryName" name="Name" class="form-control" placeholder="e.g. Beverages" required />
                    </div>

                    <div class="form-group">
                        <label for="createCategoryShortName">Short Name <span class="text-danger">*</span></label>
                        <input type="text" id="createCategoryShortName" name="ShortName" class="form-control" placeholder="e.g. BEV" maxlength="10" required />
                    </div>

                    <div class="form-group">
                        <label for="createCategoryDescription">Description <span class="text-danger">*</span></label>
                        <textarea id="createCategoryDescription" name="Description" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnSaveCategory" class="btn btn-primary" disabled>Save Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1" role="dialog" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="editCategoryModalLabel"><i class="fas fa-edit mr-2"></i> Edit Category</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="editCategoryForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="modalCategoryId" name="Id" />

                    <div class="form-group">
                        <label for="modalCategoryName">Category Name <span class="text-danger">*</span></label>
                        <input type="text" id="modalCategoryName" name="Name" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="modalCategoryShortName">Short Name <span class="text-danger">*</span></label>
                        <input type="text" id="modalCategoryShortName" name="ShortName" class="form-control" maxlength="10" required />
                    </div>

                    <div class="form-group">
                        <label for="modalCategoryDescription">Description <span class="text-danger">*</span></label>
                        <textarea id="modalCategoryDescription" name="Description" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnUpdateCategory" class="btn btn-info" disabled>Update Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["Success"] != null)
        {
                 <text>
                         Swal.fire({
                            icon: 'success',
                            title: 'Successful',
                            text: '@TempData["Success"]',
                            timer: 3000,
                            showConfirmButton: false
                         });
                 </text>
        }

        @if (TempData["Error"] != null)
        {
                 <text>
                         Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: '@TempData["Error"]',
                            timer: 4000,
                            showConfirmButton: true
                         });
                 </text>
        }

        $(document).ready(function () {

            $('#createCategoryName, #createCategoryShortName, #createCategoryDescription').on('input propertychange', function () {
                validateCreateCategoryForm();
            });

            function validateCreateCategoryForm() {
                var name = $('#createCategoryName').val().trim();
                var shortName = $('#createCategoryShortName').val().trim();
                var description = $('#createCategoryDescription').val().trim();

                if (name !== "" && shortName !== "" && description !== "") {
                    $('#btnSaveCategory').removeAttr('disabled');
                } else {
                    $('#btnSaveCategory').attr('disabled', 'disabled');
                }
            }

            $('#createCategoryModal').on('hidden.bs.modal', function () {
                $('#createCategoryForm')[0].reset();
                validateCreateCategoryForm();
            });

            $('.edit-category-btn').on('click', function () {
                var id = $(this).data('id');
                var name = $(this).data('name');
                var shortName = $(this).data('shortname');
                var description = $(this).data('description');

                $('#modalCategoryId').val(id);
                $('#modalCategoryName').val(name);
                $('#modalCategoryShortName').val(shortName);
                $('#modalCategoryDescription').val(description);

                $('#editCategoryForm').attr('action', '/Category/Edit/' + id);

                validateCategoryForm();
            });

            $('#modalCategoryName, #modalCategoryShortName, #modalCategoryDescription').on('input propertychange', function () {
                validateCategoryForm();
            });

            function validateCategoryForm() {
                var name = $('#modalCategoryName').val().trim();
                var shortName = $('#modalCategoryShortName').val().trim();
                var description = $('#modalCategoryDescription').val().trim();

                if (name !== "" && shortName !== "" && description !== "") {
                    $('#btnUpdateCategory').removeAttr('disabled');
                } else {
                    $('#btnUpdateCategory').attr('disabled', 'disabled');
                }
            }
        });
    </script>
}