@model CityMarketPOS.Models.Counter

@{
    ViewData["Title"] = "Delete Counter";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Delete Counter</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Counters</a></li>
                    <li class="breadcrumb-item active">Delete Counter</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Confirm Deletion</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <h4><i class="fas fa-exclamation-triangle"></i> Warning!</h4>
                    Are you sure you want to delete this counter? This action cannot be undone.
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Counter Name</label>
                            <p class="form-control-static">@Model.Name</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Status</label>
                            <p class="form-control-static">
                                <span class="badge badge-@(Model.Status == "Active" ? "success" : Model.Status == "Inactive" ? "secondary" : "warning")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Location</label>
                            <p class="form-control-static">@Model.Location</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Assigned User</label>
                            <p class="form-control-static">@Model.AssignedUserName</p>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Description</label>
                            <p class="form-control-static">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
