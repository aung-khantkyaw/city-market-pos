@model CityMarketPOS.Models.PurchaseOrder
@{
    // Controller ကနေ ပို့လိုက်တဲ့ Received Quantities တွေကို Dictionary အဖြစ် ပြောင်းယူခြင်း
    var receivedDict = ViewBag.ReceivedQuantities as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<section class="content">
    <div class="container-fluid">
        <div class="card card-success shadow">
            <div class="card-header">
                <h3 class="card-title">Goods Received Note (Purchase Order ID: @Model.PONumber)</h3>
            </div>
            <form asp-action="Create" method="post">
                <input type="hidden" name="poId" value="@Model.Id" />
                <div class="card-body p-0 table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th width="20%">Product Name</th>
                                <th class="text-center" width="5%">Ordered</th>
                                <th class="text-center" width="5%">Received</th>
                                <th class="text-center" width="5%">Remaining</th>
                                <th width="10%">Receiving Now</th>
                                <th width="10%">Purchase Price</th>
                                <th width="10%">Sale Price</th>
                                <th width="15%">Code Type & Value</th>
                                <th width="15%">Expiry Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                receivedDict.TryGetValue(item.ProductId, out int alreadyReceived);

                                int remainingQty = item.Quantity - alreadyReceived;
                                bool isCompleted = remainingQty <= 0;

                                <tr class="@(isCompleted ? "bg-light text-muted" : "")">
                                    <td>
                                        <strong>@item.Product.Name</strong>
                                        <input type="hidden" name="ProductId" value="@item.ProductId" />
                                    </td>
                                    <td class="text-center"><span class="badge badge-info">@item.Quantity</span></td>
                                    <td class="text-center"><span class="badge badge-secondary">@alreadyReceived</span></td>
                                    <td class="text-center">
                                        @if (isCompleted)
                                        {
                                            <span class="badge badge-success"><i class="fas fa-check"></i> 0</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning text-dark">@remainingQty</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" name="ReceivedQty" class="form-control"
                                               value="@(isCompleted ? 0 : remainingQty)"
                                               min="0" max="@(isCompleted ? 0 : remainingQty)"
                                        @(isCompleted ? "readonly" : "required") />
                                    </td>
                                    <td>
                                        <span>
                                            @item.UnitPrice
                                        </span>
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" name="SellingPrice"
                                               class="form-control"
                                               value="@item.UnitPrice"
                                               required />
                                    </td>
                                    <td>
                                        <div class="input-group">
                                            <select name="CodeType" class="form-select form-control code-type-selector" style="max-width: 110px;" @(isCompleted ? "disabled" : "")>
                                                <option value="Barcode">BarCode</option>
                                                <option value="ItemCode">ItemCode</option>
                                            </select>

                                            <span class="input-group-text category-prefix bg-light text-muted" style="display: none;">
                                                @(item.Product.Category?.ShortName ?? "UNK")-
                                            </span>

                                            <input type="hidden" name="CodePrefix" value="@item.Product.Category?.ShortName" />

                                            <input type="text" name="CodeValue" class="form-control" placeholder="Enter Code" @(isCompleted ? "readonly style=pointer-events:none;" : "") />
                                        </div>
                                    </td>
                                    <td>
                                        <input type="date" name="ExpiryDate" class="form-control" @(isCompleted ? "readonly style=pointer-events:none;" : "") />
                                        @if (!isCompleted)
                                        {
                                            <small class="text-muted">Leave blank if no expiry</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer d-flex justify-content-between bg-white">
                    <input type="text" name="Remarks" class="form-control w-50" placeholder="Notes / Remarks..." />
                    <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Confirm GRN & Update Stock</button>
                </div>
            </form>
        </div>
    </div>
</section>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('.code-type-selector').on('change', function () {
                var $row = $(this).closest('.input-group');
                var $prefix = $row.find('.category-prefix');

                if ($(this).val() === 'ItemCode') {
                    $prefix.show(); 
                } else {
                    $prefix.hide(); 
                }
            });
        });
    </script>
}