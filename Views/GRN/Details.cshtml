@model CityMarketPOS.Models.GRN

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1><i class="fas fa-box-open text-primary"></i> GRN Details</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white align-items-center">
                <h3 class="card-title mb-0">GRN Number: <strong>@Model.GRNNumber</strong></h3>
                <a asp-action="Index" class="btn btn-primary float-right font-weight-bold">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-sm-6 border-right">
                        <h6 class="text-muted text-uppercase font-weight-bold">Order Info</h6>
                        <hr class="mt-1 mb-2">
                        <p class="mb-1">PO Number: <span class="font-weight-bold text-dark">@Model.PurchaseOrder.PONumber</span></p>
                        <p class="mb-1">Received Date: <span class="text-muted">@Model.ReceivedDate.ToString("dd MMM yyyy, hh:mm tt")</span></p>
                    </div>
                    <div class="col-sm-6 pl-4">
                        <h6 class="text-muted text-uppercase font-weight-bold">Remarks</h6>
                        <hr class="mt-1 mb-2">
                        <p class="text-dark">@(string.IsNullOrWhiteSpace(Model.Remarks) ? "No remarks." : Model.Remarks)</p>
                    </div>
                </div>

                <div class="table-responsive mt-3">
                    <table class="table table-bordered table-striped">
                        <thead class="bg-light">
                            <tr>
                                <th width="5%" class="text-center">#</th>
                                <th width="20%">Product Name</th>
                                <th width="15%" class="text-center">Code (Item/Barcode)</th>
                                <th width="10%" class="text-center">Received Qty</th>
                                <th width="15%" class="text-center">Purchase Price</th>
                                <th width="15%" class="text-center">Selling Price</th>
                                <th width="15%" class="text-center">Expiry Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int serial = 1;
                            }
                            @foreach (var detail in Model.GRNDetails)
                            {
                                <tr>
                                    <td class="text-center">@serial</td>
                                    <td class="font-weight-bold">@detail.Product.Name</td>

                                    <td class="text-center">
                                        @if (!string.IsNullOrWhiteSpace(detail.ProductCode))
                                        {
                                            <span class="badge badge-info" title="Barcode"><i class="fas fa-barcode"></i> @detail.ProductCode</span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(detail.ItemCode))
                                        {
                                            <span class="badge badge-secondary" title="Item Code"><i class="fas fa-tag"></i> @detail.ItemCode</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td class="text-center text-primary font-weight-bold">@detail.ReceivedQuantity</td>
                                    <td class="text-center">@detail.PurchasePrice.ToString("N2")</td>
                                    <td class="text-center">@detail.SellingPrice.ToString("N2")</td>
                                    <td class="text-center">@(detail.ExpiryDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                </tr>
                                serial++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>