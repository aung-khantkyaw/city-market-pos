@model IEnumerable<CityMarketPOS.Models.GRN>
@{
    ViewData["Title"] = "GRN List";
}

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary shadow">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-file-invoice mr-2"></i> Goods Received Notes (GRN) History</h3>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="bg-light">
                        <tr>
                            <th>GRN #</th>
                            <th>PO Number</th>
                            <th>Received Date</th>
                            <th>Items Count</th>
                            <th>Remarks</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge badge-info">@item.GRNNumber</span></td>
                                    <td>@item.PurchaseOrder.PONumber</td>
                                    <td>@item.ReceivedDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>@item.GRNDetails.Count() items</td>
                                    <td>@item.Remarks</td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No GRN records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>