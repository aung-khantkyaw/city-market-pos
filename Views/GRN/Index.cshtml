@model IEnumerable<CityMarketPOS.Models.GRN>
@{
    string pageTitle = ViewBag.PageTitle ?? "GRN History";
    ViewData["Title"] = pageTitle;
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-8">
                <h1>
                    <i class="fas fa-file-invoice mr-2 text-primary"></i> @pageTitle
                </h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-body">
                <form asp-action="Index" method="get" class="mb-3">
                    <div class="row">
                        <div class="col-md-5">
                            <div class="form-group">
                                <label for="poNumber">PO Number</label>
                                <input type="text" id="poNumber" name="poNumber" class="form-control form-control-sm" placeholder="Enter PO Number" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="form-group">
                                <label for="receivedDate">Received Date</label>
                                <input type="date" id="receivedDate" name="receivedDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <div>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-filter"></i> Filter
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                                        <i class="fas fa-times"></i> Clear
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>GRN Number</th>
                            <th>PO Number</th>
                            <th>Received Date</th>
                            <th class="text-center">Items</th>
                            <th>Remarks</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge badge-info p-2 font-weight-bold">@item.GRNNumber</span></td>
                                <td><strong>@(item.PurchaseOrder?.PONumber ?? "N/A")</strong></td>
                                <td class="text-muted">@item.ReceivedDate.ToString("dd MMM yyyy")</td>
                                <td class="text-center"><span class="badge badge-secondary">@item.GRNDetails.Count()</span></td>
                                <td>@(string.IsNullOrWhiteSpace(item.Remarks) ? "-" : item.Remarks)</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm">
                                        <i class="fas fa-eye"></i> View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            // Preserve selected values after postback
            @if (Context.Request.Query["poNumber"].Count > 0)
            {
                <text>$('#poNumber').val('@Context.Request.Query["poNumber"]');</text>
            }
            @if (Context.Request.Query["receivedDate"].Count > 0)
            {
                <text>$('#receivedDate').val('@Context.Request.Query["receivedDate"]');</text>
            }
        });
    </script>
}