@{
    ViewData["Title"] = "Dashboard";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-8">
                <h1>
                    <i class="fas fa-tachometer-alt mr-2 text-primary"></i> Dashboard
                </h1>
            </div>
            <div class="col-sm-4">
                <span class="badge badge-info float-right mt-2">
                    @(User.IsInRole("Manager") ? "Manager" : User.IsInRole("Inventory") ? "Inventory" : "Cashier")
                </span>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid mt-3">
        
        @if (User.IsInRole("Inventory") || User.IsInRole("Manager"))
        {
            <!-- Stats Cards for Inventory and Manager -->
            <div class="row">
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>@ViewBag.TotalCategories</h3>
                            <p>Total Categories</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-tags"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>@ViewBag.TotalProducts</h3>
                            <p>Total Products</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-box"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3>@ViewBag.TotalSuppliers</h3>
                            <p>Total Suppliers</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-truck"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-danger">
                        <div class="inner">
                            <h3>@ViewBag.LowStockCount</h3>
                            <p>Low Stock Items</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Manager Analytics -->
            @if (User.IsInRole("Manager"))
            {
                <div class="row mt-3">
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-primary">
                            <div class="inner">
                                <h3>@ViewBag.TotalGRNs</h3>
                                <p>Total GRNs</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-file-invoice"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-secondary">
                            <div class="inner">
                                <h3>@ViewBag.TotalPOs</h3>
                                <p>Total Purchase Orders</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-teal">
                            <div class="inner">
                                <h3>@ViewBag.TotalStockQuantity</h3>
                                <p>Total Stock Qty</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-warehouse"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-indigo">
                            <div class="inner">
                                <h3>@ViewBag.TotalStockValue.ToString("F2")</h3>
                                <p>Stock Value ($)</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Alerts Section - Common for Inventory and Manager -->
        @if (User.IsInRole("Inventory") || User.IsInRole("Manager"))
        {
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card card-danger shadow">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-exclamation-triangle"></i> Low Stock (Reorder)</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th class="text-center">Current Stock</th>
                                        <th class="text-center">Min Level</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in ViewBag.LowStock as List<CityMarketPOS.Models.ViewModels.LowStockViewModel>)
                                    {
                                        <tr>
                                            <td><strong>@p.ProductName</strong></td>
                                            <td class="text-center">
                                                <span class="badge badge-danger" style="font-size: 14px;">@p.TotalCurrentStockQuantity</span>
                                            </td>
                                            <td class="text-center text-muted">@p.MinStockLevel</td>
                                        </tr>
                                    }
                                    @if (ViewBag.LowStock == null || ((List<CityMarketPOS.Models.ViewModels.LowStockViewModel>)ViewBag.LowStock).Count == 0)
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-3">All stocks are sufficient.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card card-warning shadow">
                        <div class="card-header"><h3 class="card-title text-dark"><i class="fas fa-calendar-times"></i> Expiring Items (Next 7 Days)</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-center">Expiry Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in ViewBag.Expiring as List<CityMarketPOS.Models.GRNDetail>)
                                    {
                                        bool isExpired = g.ExpiryDate.Value.Date < DateTime.Now.Date;

                                        <tr>
                                            <td><strong>@g.Product.Name</strong></td>
                                            <td class="text-center">@g.CurrentStockQuantity</td>
                                            <td class="text-center">
                                                @if (isExpired)
                                                {
                                                    <span class="badge badge-danger">Expired on @g.ExpiryDate?.ToString("dd MMM yyyy")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning text-dark">@g.ExpiryDate?.ToString("dd MMM yyyy")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    @if (ViewBag.Expiring == null || ((List<CityMarketPOS.Models.GRNDetail>)ViewBag.Expiring).Count == 0)
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-3">No expiring items in the next 7 days.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Manager Only: Recent Activity -->
        @if (User.IsInRole("Manager"))
        {
            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="card card-primary shadow">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-history"></i> Recent GRN Activity</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>GRN Number</th>
                                        <th>PO Number</th>
                                        <th>Received Date</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var grn in ViewBag.RecentGRNs as List<CityMarketPOS.Models.GRN>)
                                    {
                                        <tr>
                                            <td><span class="badge badge-info">@grn.GRNNumber</span></td>
                                            <td><strong>@(grn.PurchaseOrder?.PONumber ?? "N/A")</strong></td>
                                            <td>@grn.ReceivedDate.ToString("dd MMM yyyy")</td>
                                            <td>@(string.IsNullOrWhiteSpace(grn.Remarks) ? "-" : grn.Remarks)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Cashier Role: POS Dashboard with Counter Selection -->
        @if (User.IsInRole("Cashier"))
        {
            <div class="row justify-content-center">
                <div class="col-md-12">
                    <div class="card border-0 shadow-lg mb-4 rounded-lg">
                        <div class="card-header bg-success text-white d-flex align-items-center">
                            <h3 class="card-title mb-0 font-weight-bold">
                                <i class="fas fa-cash-register mr-2"></i> Welcome to the POS Terminal
                            </h3>
                        </div>

                        <div class="card-body p-4 bg-light">

                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">×</span>
                                    </button>
                                    <h5 class="font-weight-bold"><i class="icon fas fa-ban mr-2"></i> Error!</h5>
                                    @TempData["Error"]
                                </div>
                            }

                            @if (ViewBag.ActiveSession != null)
                            {
                                <div class="row justify-content-center my-4">
                                    <div class="col-md-8 col-lg-6 text-center">
                                        <div class="card border-0 shadow-sm p-4 rounded-lg border-top border-success border-3">
                                            <div class="card-body">
                                                <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                                                <h4 class="font-weight-bold text-dark">Active Session Detected</h4>
                                                <p class="lead mb-2 text-dark">You are logged in at <strong class="text-success">@ViewBag.ActiveSession.Counter.Name</strong></p>
                                                <p class="text-muted mb-4">
                                                    <i class="far fa-clock mr-1"></i> Session started: <strong>@ViewBag.ActiveSession.StartTime.ToString("dd MMM yyyy hh:mm tt")</strong>
                                                </p>

                                                <a asp-action="EndSession" asp-controller="POSSession" class="btn btn-outline-danger btn-lg rounded-pill px-4 shadow-sm">
                                                    <i class="fas fa-sign-out-alt mr-2"></i> End Session
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center mb-5 mt-2">
                                    <h4 class="font-weight-bold text-dark">Select a Counter to Start Your Shift</h4>
                                    <p class="text-muted">Choose an available counter from the list below to begin.</p>
                                </div>

                                @if (ViewBag.Counters != null && ((List<CityMarketPOS.Models.Counter>)ViewBag.Counters).Any())
                                {
                                    <div class="row">
                                        @foreach (var counter in ViewBag.Counters as List<CityMarketPOS.Models.Counter>)
                                        {
                                            <div class="col-lg-4 col-md-6 mb-4">
                                                <div class="card h-100 border-0 shadow-sm counter-card">
                                                    <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                                                        <h5 class="card-title text-primary font-weight-bold mb-0 text-center w-100">
                                                            <i class="fas fa-desktop mr-2"></i> @counter.Name
                                                        </h5>
                                                    </div>
                                                    <div class="card-body">
                                                        <ul class="list-unstyled mb-0 px-2">
                                                            <li class="mb-3 d-flex align-items-center">
                                                                <div class="bg-light p-2 rounded-circle mr-3 text-success" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                                    <i class="fas fa-map-marker-alt"></i>
                                                                </div>
                                                                <div>
                                                                    <small class="text-muted d-block lh-1">Location</small>
                                                                    <span class="font-weight-bold text-dark">@counter.Location</span>
                                                                </div>
                                                            </li>
                                                            <li class="mb-3 d-flex align-items-center">
                                                                <div class="bg-light p-2 rounded-circle mr-3 text-info" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                                    <i class="fas fa-user"></i>
                                                                </div>
                                                                <div>
                                                                    <small class="text-muted d-block lh-1">Assigned User</small>
                                                                    <span class="font-weight-bold text-dark">@(counter.AssignedUserName ?? "Unassigned")</span>
                                                                </div>
                                                            </li>
                                                            <li class="d-flex align-items-center">
                                                                <div class="bg-light p-2 rounded-circle mr-3 text-warning" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                                    <i class="fas fa-info-circle"></i>
                                                                </div>
                                                                <div>
                                                                    <small class="text-muted d-block lh-1">Status</small>
                                                                    <span class="badge badge-success px-2 py-1">@counter.Status</span>
                                                                </div>
                                                            </li>
                                                        </ul>
                                                    </div>
                                                    <div class="card-footer bg-white border-top-0 pb-4 px-4">
                                                        <form asp-action="SelectCounter" asp-controller="POSSession" method="post">
                                                            <input type="hidden" name="counterId" value="@counter.Id" />
                                                            <button type="submit" class="btn btn-primary btn-block rounded-pill shadow-sm font-weight-bold">
                                                                <i class="fas fa-play-circle mr-1"></i> Select Counter
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning shadow-sm border-0 d-flex align-items-center p-4">
                                        <i class="icon fas fa-exclamation-triangle fa-2x mr-4"></i>
                                        <div>
                                            <h5 class="mb-1 font-weight-bold">No Counters Available</h5>
                                            <p class="mb-0">There are no active counters available. Please contact your administrator.</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</section>