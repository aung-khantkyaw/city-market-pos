@{
    ViewData["Title"] = "Dashboard";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-8">
                <h1>
                    <i class="fas fa-tachometer-alt mr-2 text-primary"></i> Dashboard
                </h1>
            </div>
            <div class="col-sm-4">
                <span class="badge badge-info float-right mt-2">
                    @(User.IsInRole("Manager") ? "Manager" : User.IsInRole("Inventory") ? "Inventory" : "Cashier")
                </span>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid mt-3">
        
        @if (User.IsInRole("Inventory") || User.IsInRole("Manager"))
        {
            <!-- Stats Cards for Inventory and Manager -->
            <div class="row">
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>@ViewBag.TotalCategories</h3>
                            <p>Total Categories</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-tags"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>@ViewBag.TotalProducts</h3>
                            <p>Total Products</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-box"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3>@ViewBag.TotalSuppliers</h3>
                            <p>Total Suppliers</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-truck"></i>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-danger">
                        <div class="inner">
                            <h3>@ViewBag.LowStockCount</h3>
                            <p>Low Stock Items</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Manager Analytics -->
            @if (User.IsInRole("Manager"))
            {
                <div class="row mt-3">
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-primary">
                            <div class="inner">
                                <h3>@ViewBag.TotalGRNs</h3>
                                <p>Total GRNs</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-file-invoice"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-secondary">
                            <div class="inner">
                                <h3>@ViewBag.TotalPOs</h3>
                                <p>Total Purchase Orders</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-teal">
                            <div class="inner">
                                <h3>@ViewBag.TotalStockQuantity</h3>
                                <p>Total Stock Qty</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-warehouse"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box bg-indigo">
                            <div class="inner">
                                <h3>@ViewBag.TotalStockValue.ToString("F2")</h3>
                                <p>Stock Value ($)</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Alerts Section - Common for Inventory and Manager -->
        @if (User.IsInRole("Inventory") || User.IsInRole("Manager"))
        {
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card card-danger shadow">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-exclamation-triangle"></i> Low Stock (Reorder)</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th class="text-center">Current Stock</th>
                                        <th class="text-center">Min Level</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in ViewBag.LowStock as List<CityMarketPOS.Models.ViewModels.LowStockViewModel>)
                                    {
                                        <tr>
                                            <td><strong>@p.ProductName</strong></td>
                                            <td class="text-center">
                                                <span class="badge badge-danger" style="font-size: 14px;">@p.TotalCurrentStockQuantity</span>
                                            </td>
                                            <td class="text-center text-muted">@p.MinStockLevel</td>
                                        </tr>
                                    }
                                    @if (ViewBag.LowStock == null || ((List<CityMarketPOS.Models.ViewModels.LowStockViewModel>)ViewBag.LowStock).Count == 0)
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-3">All stocks are sufficient.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card card-warning shadow">
                        <div class="card-header"><h3 class="card-title text-dark"><i class="fas fa-calendar-times"></i> Expiring Items (Next 7 Days)</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-center">Expiry Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in ViewBag.Expiring as List<CityMarketPOS.Models.GRNDetail>)
                                    {
                                        bool isExpired = g.ExpiryDate.Value.Date < DateTime.Now.Date;

                                        <tr>
                                            <td><strong>@g.Product.Name</strong></td>
                                            <td class="text-center">@g.CurrentStockQuantity</td>
                                            <td class="text-center">
                                                @if (isExpired)
                                                {
                                                    <span class="badge badge-danger">Expired on @g.ExpiryDate?.ToString("dd MMM yyyy")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning text-dark">@g.ExpiryDate?.ToString("dd MMM yyyy")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    @if (ViewBag.Expiring == null || ((List<CityMarketPOS.Models.GRNDetail>)ViewBag.Expiring).Count == 0)
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-3">No expiring items in the next 7 days.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Manager Only: Recent Activity -->
        @if (User.IsInRole("Manager"))
        {
            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="card card-primary shadow">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-history"></i> Recent GRN Activity</h3></div>
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>GRN Number</th>
                                        <th>PO Number</th>
                                        <th>Received Date</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var grn in ViewBag.RecentGRNs as List<CityMarketPOS.Models.GRN>)
                                    {
                                        <tr>
                                            <td><span class="badge badge-info">@grn.GRNNumber</span></td>
                                            <td><strong>@(grn.PurchaseOrder?.PONumber ?? "N/A")</strong></td>
                                            <td>@grn.ReceivedDate.ToString("dd MMM yyyy")</td>
                                            <td>@(string.IsNullOrWhiteSpace(grn.Remarks) ? "-" : grn.Remarks)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Cashier Role: POS Dashboard with Counter Selection -->
        @if (User.IsInRole("Cashier"))
        {
            <div class="row">
                <div class="col-md-12">
                    <div class="card card-success shadow">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fas fa-cash-register"></i> Welcome to the POS Terminal</h3>
                        </div>
                        <div class="card-body">
                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger alert-dismissible">
                                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                                    <h5><i class="icon fas fa-ban"></i> Error!</h5>
                                    @TempData["Error"]
                                </div>
                            }

                            @if (ViewBag.ActiveSession != null)
                            {
                                <div class="alert alert-success">
                                    <h5><i class="icon fas fa-check-circle"></i> Active Session</h5>
                                    <p>You are currently logged in at <strong>@ViewBag.ActiveSession.Counter.Name</strong></p>
                                    <p>Session started: @ViewBag.ActiveSession.StartTime.ToString("dd MMM yyyy HH:mm")</p>
                                    <a asp-action="Index" asp-controller="POSTerminal" class="btn btn-primary btn-lg mt-2">
                                        <i class="fas fa-shopping-cart"></i> Go to POS Terminal
                            </a>
                            <a asp-action="TodaySales" asp-controller="POSTerminal" class="btn btn-info btn-lg mt-2 ml-2">
                                <i class="fas fa-list"></i> Today's Sales
                            </a>
                            <a asp-action="EndSession" asp-controller="POSSession" class="btn btn-danger btn-lg mt-2 ml-2">
                                <i class="fas fa-sign-out-alt"></i> End Session
                            </a>
                                </div>
                            }
                            else
                            {
                                <h4 class="text-center mb-4">Select a Counter to Start Your Shift</h4>
                                
                                @if (ViewBag.Counters != null && ((List<CityMarketPOS.Models.Counter>)ViewBag.Counters).Any())
                                {
                                    <div class="row">
                                        @foreach (var counter in ViewBag.Counters as List<CityMarketPOS.Models.Counter>)
                                        {
                                            <div class="col-md-4">
                                                <div class="card card-outline card-primary mb-3">
                                                    <div class="card-header">
                                                        <h5 class="card-title">@counter.Name</h5>
                                                    </div>
                                                    <div class="card-body">
                                                        <div class="info-box">
                                                            <span class="info-box-icon bg-success"><i class="fas fa-store"></i></span>
                                                            <div class="info-box-content">
                                                                <span class="info-box-text">Location</span>
                                                                <span class="info-box-number">@counter.Location</span>
                                                            </div>
                                                        </div>
                                                        <div class="info-box">
                                                            <span class="info-box-icon bg-info"><i class="fas fa-user"></i></span>
                                                            <div class="info-box-content">
                                                                <span class="info-box-text">Assigned User</span>
                                                                <span class="info-box-number">@(counter.AssignedUserName ?? "Unassigned")</span>
                                                            </div>
                                                        </div>
                                                        <div class="info-box">
                                                            <span class="info-box-icon bg-warning"><i class="fas fa-info-circle"></i></span>
                                                            <div class="info-box-content">
                                                                <span class="info-box-text">Status</span>
                                                                <span class="info-box-number">
                                                                    <span class="badge badge-success">@counter.Status</span>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="card-footer">
                                                        <form asp-action="SelectCounter" asp-controller="POSSession" method="post">
                                                            <input type="hidden" name="counterId" value="@counter.Id" />
                                                            <button type="submit" class="btn btn-primary btn-block">
                                                                <i class="fas fa-check"></i> Select Counter
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        <h5><i class="icon fas fa-exclamation-triangle"></i> No Counters Available</h5>
                                        There are no active counters available. Please contact your administrator to set up counters.
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</section>