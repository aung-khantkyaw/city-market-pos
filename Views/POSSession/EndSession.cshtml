@model CityMarketPOS.Models.ViewModels.SessionReportViewModel

@{
    ViewData["Title"] = "End Session Report";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Session Report</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active">Session Report</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-success shadow">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-file-invoice"></i> Daily Session Report</h3>
                    </div>
                    <div class="card-body">
                        <!-- Session Info -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="info-box bg-info">
                                    <span class="info-box-icon"><i class="fas fa-store"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Counter</span>
                                        <span class="info-box-number">@Model.Session.Counter.Name</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-box bg-warning">
                                    <span class="info-box-icon"><i class="fas fa-clock"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Session Duration</span>
                                        <span class="info-box-number">
                                            @Model.Session.StartTime.ToString("dd MMM yyyy HH:mm") - 
                                            @(Model.Session.EndTime?.ToString("HH:mm") ?? "Active")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Summary Stats -->
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="small-box bg-success">
                                    <div class="inner">
                                        <h3>@Model.TotalSales</h3>
                                        <p>Total Sales</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-shopping-cart"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="small-box bg-primary">
                                    <div class="inner">
                                        <h3>@Model.TotalItems</h3>
                                        <p>Total Items Sold</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-box"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="small-box bg-danger">
                                    <div class="inner">
                                        <h3>@Model.TotalAmount.ToString("F2")</h3>
                                        <p>Total Revenue ($)</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-dollar-sign"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sales Table -->
                        @if (Model.Sales != null && Model.Sales.Any())
                        {
                            <div class="card card-outline card-primary">
                                <div class="card-header">
                                    <h3 class="card-title">Sales Details</h3>
                                </div>
                                <div class="card-body p-0 table-responsive">
                                    <table class="table table-striped align-middle">
                                        <thead>
                                            <tr>
                                                <th>Sale #</th>
                                                <th>Time</th>
                                                <th>Items</th>
                                                <th>Subtotal</th>
                                                <th>Tax (5%)</th>
                                                <th>Discount</th>
                                                <th>Total</th>
                                                <th>Payment</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var sale in Model.Sales)
                                            {
                                                <tr>
                                                    <td><span class="badge badge-info">@sale.SaleNumber</span></td>
                                                    <td>@sale.SaleDate.ToString("HH:mm")</td>
                                                    <td>@sale.Details.Sum(d => d.Quantity)</td>
                                                    <td>@sale.Subtotal.ToString("F2")</td>
                                                    <td>@sale.Tax.ToString("F2")</td>
                                                    <td>@sale.Discount.ToString("F2")</td>
                                                    <td><strong>@sale.GrandTotal.ToString("F2")</strong></td>
                                                    <td><span class="badge badge-success">@sale.PaymentMethod</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="bg-light">
                                                <td colspan="6" class="text-right"><strong>Grand Total:</strong></td>
                                                <td colspan="2"><strong class="text-success">@Model.TotalAmount.ToString("F2")</strong></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <h5><i class="icon fas fa-info-circle"></i> No Sales</h5>
                                No sales were made during this session.
                            </div>
                        }

                        <!-- Confirm Button -->
                        <div class="row mt-4">
                            <div class="col-md-12 text-center">
                                <form asp-action="ConfirmEndSession" method="post">
                                    <input type="hidden" name="sessionId" value="@Model.Session.Id" />
                                    <button type="submit" class="btn btn-danger btn-lg">
                                        <i class="fas fa-sign-out-alt"></i> End Session & Logout
                                    </button>
                                    <a asp-action="Index" asp-controller="POSTerminal" class="btn btn-secondary btn-lg ml-2">
                                        <i class="fas fa-arrow-left"></i> Back to POS Terminal
                                    </a>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
