@model IEnumerable<CityMarketPOS.Models.Counter>

@{
    ViewData["Title"] = "Select Counter";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Select Counter</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active">Select Counter</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">

        <!-- Error Alert -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-ban"></i> Error!</h5>
                @TempData["Error"]
            </div>
        }

        <!-- Main Wrapper Card -->
        <div class="card border-0 shadow-lg mb-4 rounded-lg">
            <div class="card-body p-4 bg-light">

                <!-- Header Section -->
                <div class="text-center mb-5 mt-2">
                    <h4 class="font-weight-bold text-dark">Select a Counter to Start Your Shift</h4>
                    <p class="text-muted">Choose an available counter from the list below to begin.</p>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="row justify-content-center">
                        @foreach (var counter in Model)
                        {
                            <div class="col-lg-4 col-md-6 mb-4">
                                <div class="card h-100 border-0 shadow-sm counter-card">
                                    <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                                        <h5 class="card-title text-primary font-weight-bold mb-0 text-center w-100">
                                            <i class="fas fa-desktop mr-2"></i> @counter.Name
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <ul class="list-unstyled mb-0 px-2">
                                            <!-- Location -->
                                            <li class="mb-3 d-flex align-items-center">
                                                <div class="bg-light p-2 rounded-circle mr-3 text-success" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-map-marker-alt"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block lh-1">Location</small>
                                                    <span class="font-weight-bold text-dark">@counter.Location</span>
                                                </div>
                                            </li>
                                            <!-- Assigned User -->
                                            <li class="mb-3 d-flex align-items-center">
                                                <div class="bg-light p-2 rounded-circle mr-3 text-info" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-user"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block lh-1">Assigned User</small>
                                                    <span class="font-weight-bold text-dark">@(counter.AssignedUserName ?? "Unassigned")</span>
                                                </div>
                                            </li>
                                            <!-- Status -->
                                            <li class="d-flex align-items-center">
                                                <div class="bg-light p-2 rounded-circle mr-3 text-warning" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-info-circle"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block lh-1">Status</small>
                                                    <span class="badge badge-success px-2 py-1">@counter.Status</span>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="card-footer bg-white border-top-0 pb-4 px-4">
                                        <form asp-action="SelectCounter" asp-controller="POSSession" method="post">
                                            <input type="hidden" name="counterId" value="@counter.Id" />
                                            <button type="submit" class="btn btn-primary btn-block rounded-pill shadow-sm font-weight-bold">
                                                <i class="fas fa-play-circle mr-1"></i> Select Counter
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning shadow-sm border-0 d-flex align-items-center p-4">
                        <i class="icon fas fa-exclamation-triangle fa-2x mr-4"></i>
                        <div>
                            <h5 class="mb-1 font-weight-bold">No Counters Available</h5>
                            <p class="mb-0">There are no active counters available. Please contact your administrator.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>