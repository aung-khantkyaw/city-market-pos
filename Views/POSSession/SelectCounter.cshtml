@model IEnumerable<CityMarketPOS.Models.Counter>

@{
    ViewData["Title"] = "Select Counter";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Select Counter</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active">Select Counter</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-ban"></i> Error!</h5>
                @TempData["Error"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Available Counters</h3>
                <div class="card-tools">
                    <span class="badge badge-info">Select your counter to start POS session</span>
                </div>
            </div>
            <div class="card-body">
                @if (Model != null && Model.Any())
                {
                    <div class="row">
                        @foreach (var counter in Model)
                        {
                            <div class="col-md-4">
                                <div class="card card-outline card-primary">
                                    <div class="card-header">
                                        <h5 class="card-title">@counter.Name</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="info-box">
                                            <span class="info-box-icon bg-success"><i class="fas fa-store"></i></span>
                                            <div class="info-box-content">
                                                <span class="info-box-text">Location</span>
                                                <span class="info-box-number">@counter.Location</span>
                                            </div>
                                        </div>
                                        <div class="info-box">
                                            <span class="info-box-icon bg-info"><i class="fas fa-user"></i></span>
                                            <div class="info-box-content">
                                                <span class="info-box-text">Assigned User</span>
                                                <span class="info-box-number">@counter.AssignedUserName ?? "Unassigned"</span>
                                            </div>
                                        </div>
                                        <div class="info-box">
                                            <span class="info-box-icon bg-warning"><i class="fas fa-info-circle"></i></span>
                                            <div class="info-box-content">
                                                <span class="info-box-text">Status</span>
                                                <span class="info-box-number">
                                                    <span class="badge badge-success">@counter.Status</span>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-footer">
                                        <form asp-action="SelectCounter" method="post">
                                            <input type="hidden" name="counterId" value="@counter.Id" />
                                            <button type="submit" class="btn btn-primary btn-block">
                                                <i class="fas fa-check"></i> Select Counter
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        <h5><i class="icon fas fa-exclamation-triangle"></i> No Counters Available</h5>
                        There are no active counters available. Please contact your administrator to set up counters.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
