@model CityMarketPOS.Models.Product
<section class="content">
    <div class="container-fluid">
        <div class="card card-info">
            <div class="card-header"><h3>Edit Product</h3></div>
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><label>Barcode</label><input asp-for="Barcode" class="form-control" readonly /></div>
                        <div class="col-md-6"><label>Product Name</label><input asp-for="Name" class="form-control" /></div>
                        <div class="col-md-4">
                            <label>Category</label><select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                            <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4"><label>Brand</label><select asp-for="BrandId" class="form-control" asp-items="ViewBag.Brands">
                            <option value="">-- Select Brand --</option>
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger"></span></div>
                        <div class="col-md-4"><label>UOM</label><select asp-for="UOMId" class="form-control" asp-items="ViewBag.UOMs">
                            <option value="">-- Select UOM --</option>
                        </select>
                        <span asp-validation-for="UOMId" class="text-danger"></span></div>
                        <div class="col-md-6">
                            <label>Purchase Price</label>
                            <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label>Selling Price</label>
                            <input asp-for="SellingPrice" type="number" step="0.01" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="card-footer"><button type="submit" class="btn btn-info">Update Changes</button></div>
            </form>        </div>
        </div>
    </section>