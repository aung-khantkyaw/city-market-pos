@using CityMarketPOS.Models.ViewModels
@model PurchaseOrderViewModel

<form asp-action="Create" method="post" id="poForm">
    <div class="card shadow-sm border-0 rounded-lg">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fas fa-file-invoice-dollar"></i> Create Purchase Order</h5>
        </div>


        <div class="card-body p-4">
        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">PO Number</label>
                    <input asp-for="PONumber" class="form-control bg-light fw-bold text-primary" readonly />
                </div>

                <div class="col-md-5">
                    <label class="form-label fw-bold">Supplier</label>
                    <select asp-for="SupplierId" asp-items="@((SelectList)ViewData["Suppliers"])" class="form-select shadow-none" required>
                        <option value="">-- Select Supplier --</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle" id="orderTable">
                    <thead class="table-light">
                        <tr>
                            <th width="35%">Product</th>
                            <th width="15%">Qty</th>
                            <th width="20%">Unit Price</th>
                            <th width="20%">Total</th>
                            <th width="10%" class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-outline-success mt-2" onclick="addRow()">
                <i class="fas fa-plus-circle"></i> Add Product
            </button>
        </div>

        <div class="card-footer bg-light p-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-success fw-bold">Grand Total: <span id="grandTotal">0.00</span></h4>
            <button type="submit" class="btn btn-primary px-4 py-2">
                <i class="fas fa-save"></i> Save Purchase Order
            </button>
        </div>
    </div>
</form>

<script>
    // Controller က ပို့လိုက်တဲ့ ViewBag.ProductList ကို JSON ပြောင်းယူခြင်း
    const products = @Html.Raw(Json.Serialize(ViewBag.ProductList ?? new List<object>()));
    let rowCount = 0;

    function addRow() {
        let tbody = document.querySelector("#orderTable tbody");
        if (!tbody) return;

        let tr = document.createElement("tr");

        // C# object ရဲ့ စာလုံးအကြီးအသေး (Pascal/Camel case) ၂ မျိုးလုံးကို ခံရအောင် စစ်ပေးထားပါတယ်
        let options = products.map(p => {
            let id = p.id ?? p.Id;
            let name = p.name ?? p.Name;
            let price = p.purchasePrice ?? p.PurchasePrice ?? 0;
            return `<option value="${id}" data-price="${price}">${name}</option>`;
        }).join('');

        tr.innerHTML = `
            <td>
                <select name="OrderDetails[${rowCount}].ProductId" class="form-select prod-select shadow-none" onchange="updateRowPrice(this)" required>
                    <option value="">-- Select Product --</option>
                    ${options}
                </select>
            </td>
            <td><input type="number" name="OrderDetails[${rowCount}].Quantity" class="form-control qty-input text-end shadow-none" value="1" min="1" oninput="calculateTotal()" required></td>
            <td><input type="number" name="OrderDetails[${rowCount}].UnitPrice" class="form-control price-input text-end bg-light shadow-none" readonly></td>
            <td><input type="text" class="form-control row-total text-end bg-light shadow-none" readonly></td>
            <td class="text-center">
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        `;

        tbody.appendChild(tr);
        rowCount++; // Index ကို မထပ်အောင် တိုးပေးခြင်း
        calculateTotal();
    }

    function removeRow(btn) {
        btn.closest("tr").remove();
        calculateTotal();
    }

    function updateRowPrice(selectElement) {
        let row = selectElement.closest('tr');
        let selectedOption = selectElement.options[selectElement.selectedIndex];

        // Fetch API ခေါ်စရာမလိုဘဲ data-price ထဲကနေ စျေးနှုန်းကို တန်းယူပါတယ် (ပိုမြန်ဆန်ပါတယ်)
        let price = selectedOption.getAttribute('data-price');
        let priceInput = row.querySelector('.price-input');

        priceInput.value = price ? parseFloat(price).toFixed(2) : "0.00";
        calculateTotal();
    }

    function calculateTotal() {
        let grandTotal = 0;
        document.querySelectorAll('#orderTable tbody tr').forEach(row => {
            let qty = parseFloat(row.querySelector('.qty-input').value) || 0;
            let price = parseFloat(row.querySelector('.price-input').value) || 0;
            let total = qty * price;

            row.querySelector('.row-total').value = total.toFixed(2);
            grandTotal += total;
        });

        document.getElementById('grandTotal').innerText = grandTotal.toFixed(2);
    }

    // စာမျက်နှာ စပွင့်ပွင့်ချင်း Row တစ်ခု အလိုအလျောက် ပေါ်နေစေချင်ရင် အောက်က Line ကို ချန်ထားပါ
    // မလိုချင်ရင်တော့ ဖျက်ပစ်နိုင်ပါတယ်
    document.addEventListener("DOMContentLoaded", function() {
        addRow();
    });
</script>