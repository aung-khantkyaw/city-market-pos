@model CityMarketPOS.Models.PurchaseOrder
@{
    ViewData["Title"] = "Purchase Order Details";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1><i class="fas fa-info-circle text-info"></i> PO Details</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm border-0 rounded-lg">
            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0 font-weight-bold text-dark">
                    PO Number: <span class="text-primary">@Model.PONumber</span>
                </h4>
                <div>
                    @if (Model.Status == "Pending")
                    {
                        <span class="badge badge-warning px-3 py-2 text-dark rounded-pill" style="font-size: 0.9rem;">
                            <i class="fas fa-clock"></i> @Model.Status
                        </span>
                    }
                    else if (Model.Status == "Received")
                    {
                        <span class="badge badge-success px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                            <i class="fas fa-check-circle"></i> @Model.Status
                        </span>
                    }
                    else
                    {
                        <span class="badge badge-secondary px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                            @Model.Status
                        </span>
                    }
                </div>
            </div>

            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-sm-6">
                        <h6 class="text-muted text-uppercase font-weight-bold">Supplier Info</h6>
                        <hr class="mt-1 mb-2">
                        <h5 class="font-weight-bold text-primary">@Model.Supplier?.Name</h5>
                        <p class="mb-1 text-muted"><i class="fas fa-phone mr-1"></i> @(Model.Supplier?.Phone ?? "N/A")</p>
                        <p class="mb-1 text-muted"><i class="fas fa-envelope mr-1"></i> @(Model.Supplier?.Email ?? "N/A")</p>
                        <p class="mb-1 text-muted"><i class="fas fa-map-marker-alt mr-1"></i> @(Model.Supplier?.Address ?? "N/A")</p>
                    </div>

                    <div class="col-sm-6 text-sm-right">
                        <h6 class="text-muted text-uppercase font-weight-bold">Order Meta</h6>
                        <hr class="mt-1 mb-2">
                        <p class="mb-1"><strong>Order Date:</strong> <span class="text-muted">@Model.OrderDate.ToString("dd-MMM-yyyy hh:mm tt")</span></p>
                        @if (Model.ExpectedDate != DateTime.MinValue)
                        {
                            <p class="mb-1"><strong>Expected Date:</strong> <span class="text-muted">@Model.ExpectedDate.ToString("dd-MMM-yyyy")</span></p>
                        }
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 10%">#</th>
                                <th style="width: 65%">Product Name</th>
                                <th class="text-center" style="width: 25%">Ordered Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int serialNo = 1;
                            }
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td>@serialNo</td>
                                    <td class="font-weight-bold text-dark">@(detail.Product?.Name ?? "Unknown Product")</td>
                                    <td class="text-center font-weight-bold text-primary">@detail.Quantity</td>
                                </tr>
                                serialNo++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white pt-3 pb-3">
                <button type="button" class="btn btn-primary" onclick="window.print();">
                    <i class="fas fa-print"></i> Print PO
                </button>
                <a asp-action="Index" class="btn btn-secondary float-right">Close</a>
            </div>
        </div>
    </div>
</section>