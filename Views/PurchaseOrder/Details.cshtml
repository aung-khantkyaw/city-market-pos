@model CityMarketPOS.Models.PurchaseOrder

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1><i class="fas fa-file-invoice text-primary"></i> Purchase Order Details</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white align-items-center">
                <h3 class="card-title mb-0">PO Number: <strong>@Model.PONumber</strong></h3>
                <a asp-action="Index" class="btn btn-primary float-right font-weight-bold">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-sm-6 border-right">
                        <h6 class="text-muted text-uppercase font-weight-bold">Order Info</h6>
                        <hr class="mt-1 mb-2">
                        <p class="mb-1">Order Date: <span class="font-weight-bold text-dark">@Model.OrderDate.ToString("dd MMM yyyy")</span></p>
                        <p class="mb-1">Expected Date: <span class="text-muted">@Model.ExpectedDate.ToString("dd MMM yyyy")</span></p>
                        <p class="mb-1">
                            Status:
                            <span class="badge @(Model.Status == "Pending" ? "badge-warning" : "badge-success")">@Model.Status</span>
                        </p>
                    </div>
                    <div class="col-sm-6 pl-4">
                        <h6 class="text-muted text-uppercase font-weight-bold">Supplier Info</h6>
                        <hr class="mt-1 mb-2">
                        <p class="mb-1 text-dark"><strong>@Model.Supplier?.Name</strong></p>
                        <p class="mb-1 text-muted"><i class="fas fa-user"></i> @Model.Supplier?.ContactPerson</p>
                        <p class="mb-1 text-muted"><i class="fas fa-phone"></i> @Model.Supplier?.Phone</p>
                    </div>
                </div>

                <div class="table-responsive mt-3">
                    <table class="table table-bordered table-striped">
                        <thead class="bg-light">
                            <tr>
                                <th width="5%" class="text-center">#</th>
                                <th width="40%">Product Name</th>
                                <th width="15%" class="text-center">Order Qty</th>
                                <th width="20%" class="text-right">Unit Price</th>
                                <th width="20%" class="text-right">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int serial = 1;
                            }
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="text-center">@serial</td>
                                    <td class="font-weight-bold">@detail.Product?.Name</td>
                                    <td class="text-center text-primary font-weight-bold">@detail.Quantity</td>
                                    <td class="text-right">@detail.UnitPrice.ToString("N2")</td>
                                    <td class="text-right">@((detail.Quantity * detail.UnitPrice).ToString("N2"))</td>
                                </tr>
                                serial++;
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-right text-uppercase">Grand Total:</th>
                                <th class="text-right text-danger font-weight-bold">@Model.TotalAmount.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>