@model IEnumerable<CityMarketPOS.Models.PurchaseOrder>
@{
    ViewData["Title"] = "Purchase Orders";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1><i class="fas fa-file-invoice text-primary"></i> Purchase Orders</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header border-0 bg-white pt-3">
                <h3 class="card-title font-weight-bold">PO List</h3>
                <button type="button" class="btn btn-primary float-right" onclick="openCreateModal()">
                    <i class="fas fa-plus mr-1"></i> Create New PO
                </button>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap table-valign-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>PO Number</th>
                            <th>Supplier</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge badge-secondary p-2">@item.PONumber</span></td>
                                    <td class="font-weight-bold">@(item.Supplier?.Name ?? "N/A")</td>
                                    <td class="text-muted">@item.OrderDate.ToString("dd-MM-yyyy")</td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge badge-warning px-3 py-2 text-dark rounded-pill" style="font-size: 0.9rem;">
                                                <i class="fas fa-clock"></i> @item.Status
                                            </span>
                                        }
                                        else if (item.Status == "Received")
                                        {
                                            <span class="badge badge-success px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                                                <i class="fas fa-check-circle"></i> @item.Status
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                                                @item.Status
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        @if (item.Status == "Pending")
                                        {
                                            <a asp-controller="GRN" asp-action="Create" asp-route-poId="@item.Id" class="btn btn-sm btn-success">
                                                <i class="fas fa-truck-loading"></i> Receive Goods
                                            </a>
                                        }
                                        else if (item.Status == "Received")
                                        {
                                            <a asp-controller="GRN" asp-action="DetailsByPO" asp-route-poId="@item.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-file-alt"></i> GRN Details
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No Purchase Orders found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="poModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content" id="poModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(function () {
        $('.table').DataTable({
        "paging": true,
        "lengthChange": true,
        "searching": true,
        "ordering": true,
        "info": true,
        "autoWidth": false
        });
        });

        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: 'အောင်မြင်ပါသည်',
                text: '@TempData["Success"]',
                timer: 3000,
                showConfirmButton: false
                });
            </text>
        }

        function openCreateModal() {
        $.get('@Url.Action("Create", "PurchaseOrder")', function (data) {
        $('#poModalContent').html(data);
        $('#poModal').modal('show');
        });
        }
    </script>
}