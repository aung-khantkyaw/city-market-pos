@model IEnumerable<CityMarketPOS.Models.PurchaseOrder>
@{
    ViewData["Title"] = "Purchase Orders";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1><i class="fas fa-file-invoice text-primary"></i> Purchase Orders</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header border-0 bg-white pt-3">
                <h3 class="card-title font-weight-bold">PO List</h3>
                <button type="button" class="btn btn-primary float-right" onclick="openCreateModal()">
                    <i class="fas fa-plus mr-1"></i> Create New PO
                </button>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="mb-3">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="supplierId">Supplier</label>
                                <select id="supplierId" name="supplierId" class="form-control form-control-sm">
                                    <option value="">All Suppliers</option>
                                    @if (ViewBag.SupplierList != null)
                                    {
                                        @foreach (var item in ViewBag.SupplierList as SelectList)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="orderDate">Order Date</label>
                                <input type="date" id="orderDate" name="orderDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="status">Status</label>
                                <select id="status" name="status" class="form-control form-control-sm">
                                    @if (ViewBag.StatusList != null)
                                    {
                                        @foreach (var item in ViewBag.StatusList as List<SelectListItem>)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="categoryId">Category</label>
                                <select id="categoryId" name="categoryId" class="form-control form-control-sm">
                                    <option value="">All Categories</option>
                                    @if (ViewBag.CategoryList != null)
                                    {
                                        @foreach (var item in ViewBag.CategoryList as SelectList)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="productId">Product</label>
                                <select id="productId" name="productId" class="form-control form-control-sm">
                                    <option value="">All Products</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <div>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-filter"></i> Filter
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                                        <i class="fas fa-times"></i> Clear
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap table-valign-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>PO Number</th>
                            <th>Supplier</th>
                            <th>Date</th>
                            <th class="text-right">Total Amount</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge badge-secondary p-2">@item.PONumber</span></td>
                                    <td class="font-weight-bold">@(item.Supplier?.Name ?? "N/A")</td>
                                    <td class="text-muted">@item.OrderDate.ToString("dd-MM-yyyy")</td>
                                    <td class="text-right font-weight-bold text-success">@item.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge badge-warning px-3 py-2 text-dark rounded-pill" style="font-size: 0.9rem;">
                                                <i class="fas fa-clock"></i> @item.Status
                                            </span>
                                        }
                                        else if (item.Status == "Received")
                                        {
                                            <span class="badge badge-success px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                                                <i class="fas fa-check-circle"></i> @item.Status
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary px-3 py-2 rounded-pill" style="font-size: 0.9rem;">
                                                @item.Status
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        @if (item.Status == "Pending" || item.Status == "Partially Received")
                                        {
                                            <a asp-controller="GRN" asp-action="Create" asp-route-poId="@item.Id" class="btn btn-sm btn-success">
                                                <i class="fas fa-truck-loading"></i> Receive Goods
                                            </a>
                                        }
                                        @if (item.Status == "Received" || item.Status == "Partially Received")
                                        {
                                            <a asp-controller="GRN" asp-action="DetailsByPO" asp-route-poId="@item.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-file-alt"></i> GRN Details
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">No Purchase Orders found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="poModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="poModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(function () {
        $('.table').DataTable({
        "paging": true,
        "lengthChange": true,
        "searching": true,
        "ordering": true,
        "info": true,
        "autoWidth": false
        });

        // Function to load products
        function loadProducts(categoryId) {
            var productIdSelect = $('#productId');
            
            if (!categoryId || categoryId === '') {
                // Load all products when no category selected
                console.log('Loading all products...');
                $.get('@Url.Action("GetAllProducts", "PurchaseOrder")', function (data) {
                    console.log('Products loaded:', data);
                    productIdSelect.empty();
                    productIdSelect.append('<option value="">All Products</option>');
                    $.each(data, function (i, item) {
                        productIdSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                    });
                }).fail(function(xhr, status, error) {
                    console.error('Error loading products:', error);
                });
            } else {
                // Load products for specific category
                console.log('Loading products for category:', categoryId);
                $.get('@Url.Action("GetProductsByCategory", "PurchaseOrder")', { categoryId: categoryId }, function (data) {
                    console.log('Products loaded:', data);
                    productIdSelect.empty();
                    productIdSelect.append('<option value="">All Products</option>');
                    $.each(data, function (i, item) {
                        productIdSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                    });
                }).fail(function(xhr, status, error) {
                    console.error('Error loading products:', error);
                });
            }
        }

        // Load all products on page load
        loadProducts('');

        // Load products when category changes
        $('#categoryId').change(function () {
            var categoryId = $(this).val();
            loadProducts(categoryId);
        });

        // Preserve selected values after postback
        @if (Context.Request.Query["supplierId"].Count > 0)
        {
            <text>$('#supplierId').val('@Context.Request.Query["supplierId"]');</text>
        }
        @if (Context.Request.Query["orderDate"].Count > 0)
        {
            <text>$('#orderDate').val('@Context.Request.Query["orderDate"]');</text>
        }
        @if (Context.Request.Query["status"].Count > 0)
        {
            <text>$('#status').val('@Context.Request.Query["status"]');</text>
        }
        @if (Context.Request.Query["categoryId"].Count > 0)
        {
            <text>
                $('#categoryId').val('@Context.Request.Query["categoryId"]');
                // Trigger change to load products
                $('#categoryId').change();
                // Then select the product
                @if (Context.Request.Query["productId"].Count > 0)
                {
                    <text>setTimeout(function() { $('#productId').val('@Context.Request.Query["productId"]'); }, 100);</text>
                }
            </text>
        }
        });

        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: 'Successful',
                text: '@TempData["Success"]',
                timer: 3000,
                showConfirmButton: false
                });
            </text>
        }

        function openCreateModal() {
        $.get('@Url.Action("Create", "PurchaseOrder")', function (data) {
        $('#poModalContent').html(data);
        $('#poModal').modal('show');
        });
        }
    </script>
}