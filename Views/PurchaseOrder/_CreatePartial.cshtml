@model CityMarketPOS.Models.ViewModels.PurchaseOrderCreateViewModel

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title mb-0"><i class="fas fa-file-invoice"></i> Create Purchase Order</h5>
    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<form asp-action="Create" method="post" id="poForm">
    @Html.AntiForgeryToken()
    <div class="modal-body p-4">

        <div class="form-group mb-3">
            <label class="form-label fw-bold">PO Number</label>
            <input asp-for="PONumber" class="form-control bg-light fw-bold text-primary" readonly />
        </div>

        <div class="form-group mb-3">
            <label class="form-label fw-bold">Select Product <span class="text-danger">*</span></label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductList" class="form-control" id="modalProductDropdown" required>
                <option value="">-- Choose Product --</option>
            </select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="form-label fw-bold">Select Supplier <span class="text-danger">*</span></label>
            <select asp-for="SupplierId" class="form-control" id="modalSupplierDropdown" required disabled>
                <option value="">-- Select Product First --</option>
            </select>
            <span asp-validation-for="SupplierId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="form-label fw-bold">Quantity (Qty) <span class="text-danger">*</span></label>
            <input asp-for="Quantity" type="number" class="form-control text-end" min="1" value="1" required />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

    </div>
    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save PO</button>
    </div>
</form>

<script>
    $('#modalProductDropdown').change(function () {
        var productId = $(this).val();
        var supplierSelect = $('#modalSupplierDropdown');

        if (!productId) {
            supplierSelect.empty().append('<option value="">-- Select Product First --</option>').attr('disabled', true);
            return;
        }

        $.getJSON('/PurchaseOrder/GetSuppliersByProduct', { productId: productId }, function (data) {
            supplierSelect.empty();
            if (data && data.length > 0) {
                supplierSelect.append('<option value="">-- Choose Supplier --</option>');
                $.each(data, function (index, item) {
                    supplierSelect.append($('<option>', {
                        value: item.value,
                        text: item.text
                    }));
                });
                supplierSelect.attr('disabled', false);
            } else {
                supplierSelect.append('<option value="">No suppliers available</option>').attr('disabled', true);
            }
        });
    });
</script>