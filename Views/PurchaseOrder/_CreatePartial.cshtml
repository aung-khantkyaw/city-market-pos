@model CityMarketPOS.Models.ViewModels.PurchaseOrderCreateViewModel

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title mb-0"><i class="fas fa-file-invoice"></i> Create Purchase Order</h5>
    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<form asp-action="Create" method="post" id="poForm">
    @Html.AntiForgeryToken()
    <div class="modal-body p-4">

        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label class="form-label fw-bold">PO Number</label>
                <input asp-for="PONumber" class="form-control bg-light fw-bold text-primary" readonly />
            </div>

            <div class="col-md-6 form-group mb-3">
                <label class="form-label fw-bold">Select Supplier <span class="text-danger">*</span></label>
                <select asp-for="SupplierId" asp-items="ViewBag.SupplierList" class="form-control" id="mainSupplierDropdown" required>
                    <option value="">-- Choose Supplier --</option>
                </select>
                <span asp-validation-for="SupplierId" class="text-danger"></span>
            </div>
        </div>

        <hr />
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="fw-bold m-0">Order Items</h6>
            <button type="button" class="btn btn-sm btn-info" id="btnAddRow" disabled>
                <i class="fas fa-plus"></i> Add Product
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-sm">
                <thead class="bg-light">
                    <tr>
                        <th>Product <span class="text-danger">*</span></th>
                        <th width="20%">Quantity <span class="text-danger">*</span></th>
                        <th width="10%" class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody id="itemsBody">
                </tbody>
            </table>
        </div>

    </div>
    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save PO</button>
    </div>
</form>

<script>
    $(document).ready(function () {
        var currentSupplierProducts = [];

        $('#mainSupplierDropdown').change(function () {
            var supplierId = $(this).val();
            $('#itemsBody').empty();

            if (!supplierId) {
                $('#btnAddRow').attr('disabled', true);
                return;
            }
            
            $.getJSON('/PurchaseOrder/GetProductsBySupplier', { supplierId: supplierId }, function (data) {
                currentSupplierProducts = data; 

                if (data.length > 0) {
                    $('#btnAddRow').attr('disabled', false);
                    addRow(); 
                } else {
                    $('#btnAddRow').attr('disabled', true);
                    alert("This supplier has no registered products.");
                }
            });
        });

        $('#btnAddRow').click(function () {
            addRow();
        });

        $(document).on('click', '.btn-remove-row', function () {
            if ($('#itemsBody tr').length > 1) {
                $(this).closest('tr').remove();
                reindexRows();
            } else {
                alert("At least one product is required.");
            }
        });

        function addRow() {
            var options = '<option value="">-- Select Product --</option>';
            $.each(currentSupplierProducts, function (index, item) {
                options += `<option value="${item.value}">${item.text}</option>`;
            });

            var tr = `
                <tr>
                    <td>
                        <select class="form-control product-select" required>
                            ${options}
                        </select>
                    </td>
                    <td>
                        <input type="number" class="form-control qty-input text-end" value="1" min="1" required />
                    </td>
                    <td class="text-center align-middle">
                        <button type="button" class="btn btn-sm btn-danger btn-remove-row">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
            $('#itemsBody').append(tr);
            reindexRows();
        }

        function reindexRows() {
            $('#itemsBody tr').each(function (index, element) {
                $(element).find('.product-select').attr('name', `Items[${index}].ProductId`);
                $(element).find('.qty-input').attr('name', `Items[${index}].Quantity`);
            });
        }
    });
</script>