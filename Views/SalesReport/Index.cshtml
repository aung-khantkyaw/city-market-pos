@{
    ViewData["Title"] = "Sales Reports";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Sales Reports</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active">Sales Reports</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <!-- Filter Form -->
        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-filter"></i> Filter Sales</h3>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Start Date</label>
                            <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>End Date</label>
                            <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Cashier</label>
                            <select name="cashierId" class="form-control">
                                <option value="">All Cashiers</option>
                                @if (ViewBag.Cashiers != null)
                                {
                                    foreach (var cashier in ViewBag.Cashiers)
                                    {
                                        <option value="@cashier.CashierId" selected="@(ViewBag.CashierId == cashier.CashierId)">@cashier.CashierName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Counter</label>
                            <select name="counterId" class="form-control">
                                <option value="">All Counters</option>
                                @if (ViewBag.Counters != null)
                                {
                                    foreach (var counter in ViewBag.Counters)
                                    {
                                        <option value="@counter.Id" selected="@(ViewBag.CounterId == counter.Id)">@counter.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> Apply Filters
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Clear Filters
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@ViewBag.TotalSales</h3>
                        <p>Total Sales</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@ViewBag.TotalAmount.ToString("F2")</h3>
                        <p>Total Revenue ($)</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@ViewBag.TotalItems</h3>
                        <p>Total Items Sold</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-box"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@ViewBag.TotalTax.ToString("F2")</h3>
                        <p>Total Tax (5%)</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-percentage"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sales Table -->
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-list"></i> Sales Details</h3>
            </div>
            <div class="card-body p-0 table-responsive">
                @if (ViewBag.Sales != null && ((List<CityMarketPOS.Models.Sale>)ViewBag.Sales).Any())
                {
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Sale #</th>
                                <th>Date/Time</th>
                                <th>Cashier</th>
                                <th>Counter</th>
                                <th>Items</th>
                                <th>Subtotal</th>
                                <th>Tax</th>
                                <th>Discount</th>
                                <th>Total</th>
                                <th>Payment</th>
                                @* <th>Actions</th> *@
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in ViewBag.Sales as List<CityMarketPOS.Models.Sale>)
                            {
                                <tr>
                                    <td><span class="badge badge-info">@sale.SaleNumber</span></td>
                                    <td>@sale.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@sale.CashierName</td>
                                    <td>@sale.POSSession?.Counter?.Name</td>
                                    <td>@sale.Details.Sum(d => d.Quantity)</td>
                                    <td>@sale.Subtotal.ToString("F2")</td>
                                    <td>@sale.Tax.ToString("F2")</td>
                                    <td>@sale.Discount.ToString("F2")</td>
                                    <td><strong>@sale.GrandTotal.ToString("F2")</strong></td>
                                    <td><span class="badge badge-success">@sale.PaymentMethod</span></td>
                                    @* <td>
                                        <a asp-action="SessionReport" asp-route-sessionId="@sale.POSSessionId" class="btn btn-sm btn-info">
                                            <i class="fas fa-file-invoice"></i> Session
                                        </a>
                                    </td> *@
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="bg-light">
                                <td colspan="6" class="text-right"><strong>Grand Total:</strong></td>
                                <td><strong>@ViewBag.TotalTax.ToString("F2")</strong></td>
                                <td><strong>@ViewBag.TotalDiscount.ToString("F2")</strong></td>
                                <td colspan="3"><strong class="text-success">@ViewBag.TotalAmount.ToString("F2")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="alert alert-info m-3">
                        <h5><i class="icon fas fa-info-circle"></i> No Sales Found</h5>
                        No sales found for the selected criteria.
                    </div>
                }
            </div>
        </div>

        <!-- Quick Actions -->
        @* <div class="row mt-3">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Quick Actions</h3>
                    </div>
                    <div class="card-body">
                        <div class="btn-group mr-2">
                            <a asp-action="InventoryValuation" class="btn btn-info">
                                <i class="fas fa-calculator"></i> Inventory Valuation
                            </a>
                        </div>
                        <div class="btn-group mr-2">
                            <a asp-action="StockMovement" class="btn btn-success">
                                <i class="fas fa-exchange-alt"></i> Stock Movement
                            </a>
                        </div>
                        <div class="btn-group">
                            <a asp-action="Index" asp-controller="AuditLog" class="btn btn-warning">
                                <i class="fas fa-history"></i> Audit Logs
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div> *@
    </div>
</div>
