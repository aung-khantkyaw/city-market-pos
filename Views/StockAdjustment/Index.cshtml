@model IEnumerable<CityMarketPOS.Models.StockAdjustment>

@{
    ViewData["Title"] = "Stock Adjustments";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Stock Adjustments</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active">Stock Adjustments</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Stock Adjustment History</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> New Adjustment
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>Type</th>
                            <th>Quantity</th>
                            <th>Reason</th>
                            <th>Adjusted By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.AdjustmentDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@item.GRNDetail?.Product?.Name</td>
                                    <td>
                                        <span class="badge badge-@(item.AdjustmentType == "In" || item.AdjustmentType == "Correction" ? "success" : "danger")">
                                            @item.AdjustmentType
                                        </span>
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td>@item.Reason</td>
                                    <td>@item.AdjustedByUserName</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">No stock adjustments recorded</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
