@{
    ViewData["Title"] = "Add Stock Taking Details";
    var stockTaking = ViewBag.StockTaking as CityMarketPOS.Models.StockTaking;
    var grnDetails = ViewBag.GRNDetails as System.Collections.Generic.List<CityMarketPOS.Models.GRNDetail>;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Add Stock Taking Details</h1>
                <small>@stockTaking?.StockTakingNumber</small>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Stock Taking</a></li>
                    <li class="breadcrumb-item active">Add Details</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Add Item Count</h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="AddDetails" method="post">
                            <input type="hidden" name="id" value="@stockTaking?.Id" />
                            
                            <div class="form-group">
                                <label>Stock Item</label>
                                <select name="grnDetailId" class="form-control" required>
                                    <option value="">-- Select Item --</option>
                                    @if (grnDetails != null)
                                    {
                                        foreach (var item in grnDetails)
                                        {
                                            <option value="@item.Id">@item.Product?.Name (Expected: @item.CurrentStockQuantity)</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Actual Quantity</label>
                                <input type="number" name="actualQuantity" class="form-control" min="0" required />
                            </div>

                            <div class="form-group">
                                <label>Notes (Optional)</label>
                                <input type="text" name="notes" class="form-control" />
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Add Count
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Counted Items (@stockTaking?.Details.Count)</h3>
                        <div class="card-tools">
                            <a asp-action="Complete" asp-route-id="@stockTaking?.Id" class="btn btn-sm btn-success">
                                <i class="fas fa-check"></i> Complete Stock Taking
                            </a>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Expected</th>
                                    <th>Actual</th>
                                    <th>Variance</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (stockTaking?.Details != null && stockTaking.Details.Any())
                                {
                                    foreach (var detail in stockTaking.Details)
                                    {
                                        <tr>
                                            <td>@detail.GRNDetail?.Product?.Name</td>
                                            <td>@detail.ExpectedQuantity</td>
                                            <td>@detail.ActualQuantity</td>
                                            <td>
                                                <span class="badge badge-@(detail.Variance == 0 ? "success" : detail.Variance > 0 ? "warning" : "danger")">
                                                    @detail.Variance
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge badge-info">@detail.GRNDetail?.ItemCode</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">No items counted yet</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
