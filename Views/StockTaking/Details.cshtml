@model CityMarketPOS.Models.StockTaking

@{
    ViewData["Title"] = "Stock Taking Details";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Stock Taking Details</h1>
                <small>@Model.StockTakingNumber</small>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Stock Taking</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Stock Taking Information</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Stock Taking Number</label>
                            <p class="form-control-static">@Model.StockTakingNumber</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Status</label>
                            <p class="form-control-static">
                                <span class="badge badge-@(Model.Status == "Completed" ? "success" : Model.Status == "In Progress" ? "warning" : "danger")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Taking Date</label>
                            <p class="form-control-static">@Model.TakingDate.ToString("yyyy-MM-dd HH:mm:ss")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Conducted By</label>
                            <p class="form-control-static">@Model.ConductedByUserName</p>
                        </div>
                    </div>
                </div>
                @if (Model.CompletedDate.HasValue)
                {
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Completed Date</label>
                                <p class="form-control-static">@Model.CompletedDate.Value.ToString("yyyy-MM-dd HH:mm:ss")</p>
                            </div>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Remarks))
                {
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Remarks</label>
                                <p class="form-control-static">@Model.Remarks</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Counted Items (@Model.Details.Count)</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Item Code</th>
                            <th>Expected</th>
                            <th>Actual</th>
                            <th>Variance</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Details != null && Model.Details.Any())
                        {
                            foreach (var detail in Model.Details)
                            {
                                <tr>
                                    <td>@detail.GRNDetail?.Product?.Name</td>
                                    <td>@detail.GRNDetail?.ItemCode</td>
                                    <td>@detail.ExpectedQuantity</td>
                                    <td>@detail.ActualQuantity</td>
                                    <td>
                                        <span class="badge badge-@(detail.Variance == 0 ? "success" : detail.Variance > 0 ? "warning" : "danger")">
                                            @detail.Variance
                                        </span>
                                    </td>
                                    <td>@detail.Notes</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No items counted</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
