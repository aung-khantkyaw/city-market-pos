@model IEnumerable<CityMarketPOS.Models.Supplier>
@{
    ViewData["Title"] = "Suppliers";
}

<section class="content-header">
    <div class="container-fluid"><div class="row mb-2"><div class="col-sm-6"><h1>Supplier Management</h1></div></div></div>
</section>

<section class="content">
    <div class="container-fluid">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check"></i> @TempData["Success"]<button type="button" class="close" data-dismiss="alert">&times;</button></div>
        }
        <div class="card card-primary card-outline shadow">
            <div class="card-header d-flex align-items-center">
                <h3 class="card-title"><i class="fas fa-truck mr-2"></i> Supplier List</h3>
                <a asp-action="Create" class="btn btn-primary btn-sm ml-auto"><i class="fas fa-plus"></i> Add Supplier</a>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Contact Person</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Address</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.ContactPerson</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td>
                                    <div class="d-flex">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm mr-2"><i class="fas fa-edit"></i> Edit</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this supplier?');">
                                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>