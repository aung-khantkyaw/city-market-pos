@model IEnumerable<CityMarketPOS.Models.Supplier>
@{
    ViewData["Title"] = "Suppliers";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Supplier Management</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="card card-primary card-outline shadow">
            <div class="card-header d-flex align-items-center">
                <h3 class="card-title"><i class="fas fa-truck mr-2"></i> Supplier List</h3>
                <button type="button" class="btn btn-primary btn-sm ml-auto" onclick="openCreateModal()">
                    <i class="fas fa-plus"></i> Add Supplier
                </button>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Contact Person</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Supplied Products</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.ContactPerson</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.Products != null && item.Products.Any())
                                    {
                                        @foreach (var prod in item.Products)
                                        {
                                            <span class="badge badge-info mr-1">@prod.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No products assigned</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex">
                                        <button type="button" class="btn btn-info btn-sm mr-2" onclick="openEditModal(@item.Id)">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this supplier?');">
                                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="supplierModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="modalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["Success"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Successful',
                        text: '@TempData["Success"]',
                        timer: 3000,
                        showConfirmButton: false
                    });
                </text>
        }

        function openCreateModal() {
            $.get('@Url.Action("Create", "Supplier")', function (data) {
                $('#modalContent').html(data);
                $('#supplierModal').modal('show');
            });
        }

        function openEditModal(id) {
            $.get('@Url.Action("Edit", "Supplier")/' + id, function (data) {
                $('#modalContent').html(data);
                $('#supplierModal').modal('show');
            });
        }
    </script>
}