@model CityMarketPOS.Models.Supplier

<div class="modal-header bg-info text-white">
    <h5 class="modal-title"><i class="fas fa-edit mr-2"></i> Edit Supplier</h5>
    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="modal-body">
        <div class="row">
            <div class="col-md-6 form-group">
                <label asp-for="Name">Company/Supplier Name <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="ContactPerson">Contact Person</label>
                <input asp-for="ContactPerson" class="form-control" />
            </div>
            <div class="col-md-6 form-group">
                <label>Phone Numbers</label>
                <div id="phoneContainer">
                    @{
                        var phones = string.IsNullOrEmpty(Model.Phone) ? new string[0] : Model.Phone.Split(',', StringSplitOptions.RemoveEmptyEntries);

                        if (phones.Length == 0)
                        {
                            <div class="input-group mb-2 phone-input-group">
                                <input type="text" name="phoneNumbers" class="form-control" placeholder="Phone 1" />
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-success add-phone"><i class="fas fa-plus"></i></button>
                                </div>
                            </div>
                        }
                        else
                        {
                            for (int i = 0; i < phones.Length; i++)
                            {
                                <div class="input-group mb-2 phone-input-group">
                                    <input type="text" name="phoneNumbers" class="form-control" value="@phones[i].Trim()" />
                                    <div class="input-group-append">
                                        @if (i == 0)
                                        {
                                            <button type="button" class="btn btn-success add-phone"><i class="fas fa-plus"></i></button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-danger remove-phone"><i class="fas fa-minus"></i></button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
            <div class="col-md-12 form-group">
                <label asp-for="Address">Address</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>

            <div class="col-md-12 form-group border-top pt-3 mt-2">
                <label class="font-weight-bold text-info mb-3">Supply Products Setup</label>

                <div class="row">
                    <div class="col-md-5">
                        <label class="text-muted"><i class="fas fa-filter"></i> 1. Filter by Category</label>
                        <select id="editCategoryFilter" class="form-control custom-select">
                            <option value="all">-- All Categories --</option>
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in ViewBag.Categories as IEnumerable<CityMarketPOS.Models.Category>)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                        <small class="form-text text-muted mt-2">Category ပြောင်းရွေးသော်လည်း ရွေးချယ်ထားသော Product များ မပျောက်ပါ။</small>
                    </div>

                    <div class="col-md-7">
                        <label class="text-muted"><i class="fas fa-check-square"></i> 2. Select Products</label>
                        <div id="editProductContainer" class="border rounded p-3" style="height: 220px; overflow-y: auto; background-color: #f8f9fa;">
                            @{
                                var selectedIds = ViewBag.SelectedProducts as int[] ?? new int[0];
                                var products = ViewBag.Products as IEnumerable<CityMarketPOS.Models.Product>;
                            }

                            @if (products != null)
                            {
                                foreach (var prod in products)
                                {
                                    bool isChecked = selectedIds.Contains(prod.Id);
                                    <div class="custom-control custom-checkbox edit-product-item mb-2" data-category="@prod.CategoryId">
                                        <input type="checkbox" class="custom-control-input" name="selectedProductIds" value="@prod.Id" id="edit_prod_@prod.Id" @(isChecked ? "checked" : "")>
                                        <label class="custom-control-label" for="edit_prod_@prod.Id" style="cursor: pointer;">
                                            @prod.Name
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-info">Update Changes</button>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#editCategoryFilter').on('change', function () {
            var selectedCat = $(this).val();

            if (selectedCat === 'all') {
                $('.edit-product-item').fadeIn(200);
            } else {
                $('.edit-product-item').hide();
                $('.edit-product-item[data-category="' + selectedCat + '"]').fadeIn(200);
            }
        });
    });

        $(document).off('click', '.add-phone').on('click', '.add-phone', function () {
            var newField = `
                <div class="input-group mb-2 phone-input-group">
                    <input type="text" name="phoneNumbers" class="form-control" placeholder="Additional Phone" />
                    <div class="input-group-append">
                        <button type="button" class="btn btn-danger remove-phone"><i class="fas fa-minus"></i></button>
                    </div>
                </div>
            `;
            $('#phoneContainer').append(newField);
        });

        $(document).off('click', '.remove-phone').on('click', '.remove-phone', function () {
            $(this).closest('.phone-input-group').remove();
        });
</script>