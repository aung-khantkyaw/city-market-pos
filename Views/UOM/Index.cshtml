@model IEnumerable<CityMarketPOS.Models.UOM>
@{
    ViewData["Title"] = "UOMs";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Unit of Measurement (UOM)</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline shadow">
            <div class="card-header d-flex align-items-center">
                <h3 class="card-title"><i class="fas fa-balance-scale mr-2"></i> UOM List</h3>
                <button type="button" class="btn btn-primary btn-sm ml-auto" data-toggle="modal" data-target="#createUomModal">
                    <i class="fas fa-plus"></i> Add UOM
                </button>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Short Name (Abbreviation)</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td><span class="badge badge-secondary">@item.ShortName</span></td>
                                <td>
                                    <div class="d-flex">
                                        <button type="button"
                                                class="btn btn-info btn-sm mr-2 edit-uom-btn"
                                                data-toggle="modal"
                                                data-target="#editUomModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                data-shortname="@item.ShortName">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this UOM?');">
                                            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="createUomModal" tabindex="-1" role="dialog" aria-labelledby="createUomModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createUomModalLabel"><i class="fas fa-plus mr-2"></i> Add New UOM</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="Create" method="post" id="createUomForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="createName">Unit Name</label>
                        <input type="text" id="createName" name="Name" class="form-control" placeholder="e.g. Pieces / Kilogram" required />
                    </div>
                    <div class="form-group">
                        <label for="createShortName">Short Name</label>
                        <input type="text" id="createShortName" name="ShortName" class="form-control" placeholder="e.g. PCS / KG" required />
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnSave" class="btn btn-primary" disabled>Save UOM</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUomModal" tabindex="-1" role="dialog" aria-labelledby="editUomModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="editUomModalLabel"><i class="fas fa-edit mr-2"></i> Edit UOM</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="editUomForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="modalUomId" name="Id" />

                    <div class="form-group">
                        <label for="modalUomName">Unit Name</label>
                        <input type="text" id="modalUomName" name="Name" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="modalUomShortName">Short Name</label>
                        <input type="text" id="modalUomShortName" name="ShortName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnUpdate" class="btn btn-info" disabled>Update UOM</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["Success"] != null)
        {
                     <text>
                                 Swal.fire({
                                    icon: 'success',
                                    title: 'Successful',
                                    text: '@TempData["Success"]',
                                    timer: 3000,
                                    showConfirmButton: false
                                 });
                     </text>
        }

        $(document).ready(function () {

            // --- Create Logic ---
            $('#createName, #createShortName').on('input', function () {
                var name = $('#createName').val().trim();
                var shortName = $('#createShortName').val().trim();
                if (name !== "" && shortName !== "") {
                    $('#btnSave').removeAttr('disabled');
                } else {
                    $('#btnSave').attr('disabled', 'disabled');
                }
            });

            // Modal ပိတ်လိုက်ရင် Form ထဲကစာတွေကို Reset လုပ်မယ်
            $('#createUomModal').on('hidden.bs.modal', function () {
                $('#createUomForm')[0].reset();
                $('#btnSave').attr('disabled', 'disabled');
            });

            // --- Edit Logic ---
            $('.edit-uom-btn').on('click', function () {
                var id = $(this).data('id');
                var name = $(this).data('name');
                var shortName = $(this).data('shortname');

                $('#modalUomId').val(id);
                $('#modalUomName').val(name);
                $('#modalUomShortName').val(shortName);

                $('#editUomForm').attr('action', '/UOM/Edit/' + id);

                validateEditForm();
            });

            $('#modalUomName, #modalUomShortName').on('input', function () {
                validateEditForm();
            });

            function validateEditForm() {
                var name = $('#modalUomName').val().trim();
                var shortName = $('#modalUomShortName').val().trim();

                if (name !== "" && shortName !== "") {
                    $('#btnUpdate').removeAttr('disabled');
                } else {
                    $('#btnUpdate').attr('disabled', 'disabled');
                }
            }
        });
    </script>
}